{
  "name": "@nile-squad/nylonpay-ts",
  "version": "1.0.5",
  "description": "Nylon Pay SDK for merchant integrations",
  "keywords": [
    "nylonpay",
    "nylon-pay",
    "payments",
    "mobile-money",
    "payouts",
    "fintech",
    "sdk",
    "typescript"
  ],
  "homepage": "https://github.com/nile-squad/nylonpay-ts#readme",
  "bugs": {
    "url": "https://github.com/nile-squad/nylonpay-ts/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nile-squad/nylonpay-ts.git"
  },
  "author": "Nile Squad <contact@nilesquad.com> (https://nilesquad.com)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "export": "tsc --noEmit && biome check . && tsup",
    "prepublishOnly": "vitest run && tsc --noEmit && biome check . && tsup"
  },
  "dependencies": {
    "slang-ts": "^0.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@types/node": "^22.0.0",
    "dotenv": "^17.3.1",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
